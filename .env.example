DATABASE_URL="postgresql://postgres:postgres@localhost:5433/marketing_ai_platform?schema=public"

# App / Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
AI_MODEL_ENCRYPTION_SALT="replace-with-stable-random-salt"
# Public origin used to build links in transactional emails (password reset, email verification).
# Falls back to http://localhost:3000 when unset. Set to the production origin on Vercel.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Chat LLM provider: use your own OpenAI-compatible gateway/model registry.
OPENROUTER_API_KEY=""
FLEXION_API_BASE_URL=""
FLEXION_API_KEY=""
CONVERSATION_AI_MODEL="gpt-5.4"
CONVERSATION_MODEL_OPTIONS="claude-opus-4-7|Claude Opus 4.7,gemini-3.1-pro-preview|Gemini 3.1 Pro Preview,gpt-5.4|GPT-5.4"
TRADE_VISION_MODEL="gpt-5.4"
FLEXION_APP_TITLE="Marketing AI Platform"

# Marketing intelligence/search: always uses OpenRouter + Perplexity models.
MARKETING_INTELLIGENCE_ENABLED="true"

# Image generation / Banana 2 + Banana Pro
GEMINI_API_KEY=""
BANANA_IMAGE_MODEL="nano-banana-2"
BANANA_IMAGE_SIZE="2K"
BANANA_IMAGE_OUTPUT_FORMAT="png"
BANANA_IMAGE_CREDIT_COST="20000"

# Optional Anthropic fallback
ANTHROPIC_API_KEY=""
ANTHROPIC_API_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_VERSION="2023-06-01"

# Email
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# Billing / payment
ECPAY_MERCHANT_ID=""
ECPAY_HASH_KEY=""
ECPAY_HASH_IV=""
ECPAY_RETURN_URL="http://localhost:3000/api/webhooks/ecpay"

# Taiwan company lookup
GCIS_API_BASE_URL="https://data.gcis.nat.gov.tw/od/data/api"

# Google Analytics integration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/google-analytics/callback"
GA_TOKEN_ENCRYPTION_SALT="replace-with-openssl-rand-base64-32"

# Optional LINE login / connector prep
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# Optional asset / CDN base URL
ASSET_BASE_URL=""

# Optional local infra / future analytics cache
REDIS_URL=""
